#!/usr/bin/env bash
# isoclaude — run Claude Code in a sandboxed container.
#
# Phase 2 surface: default run path only. Subcommands (init/update/pin/
# version/shell/build) are added in Phase 3, project-level config overlays
# in Phase 4, and the installer in Phase 5.
#
# Compatible with bash 3.2 (macOS default). Avoids mapfile, lone arr[@]
# under set -u, etc.

set -eo pipefail

ISOCLAUDE_HOME="${ISOCLAUDE_HOME:-$HOME/.isoclaude}"
ISOCLAUDE_BASE_IMAGE="${ISOCLAUDE_BASE_IMAGE:-isoclaude-base:latest}"
NPM_PACKAGE="@anthropic-ai/claude-code"

# Globals populated by compose_*; consumed by run_default.
RUN_FLAGS=()

log()  { printf '\033[2misoclaude:\033[0m %s\n' "$*" >&2; }
warn() { printf '\033[33misoclaude:\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[31misoclaude:\033[0m %s\n' "$*" >&2; exit 1; }

script_dir() {
    # Resolve $0 through any symlinks to find the script's real dir.
    local src="${BASH_SOURCE[0]}" dir
    while [ -L "$src" ]; do
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        case "$src" in /*) ;; *) src="$dir/$src" ;; esac
    done
    cd -P "$(dirname "$src")" && pwd
}

detect_runtime() {
    if [ -n "${ISOCLAUDE_RUNTIME:-}" ]; then
        command -v "$ISOCLAUDE_RUNTIME" >/dev/null 2>&1 \
            || die "ISOCLAUDE_RUNTIME=$ISOCLAUDE_RUNTIME not on PATH"
        printf '%s\n' "$ISOCLAUDE_RUNTIME"
        return
    fi
    local r
    for r in container orb docker podman; do
        if command -v "$r" >/dev/null 2>&1; then
            printf '%s\n' "$r"
            return
        fi
    done
    die "no container runtime found (looked for: container, orb, docker, podman)"
}

# Walk up from PWD looking for a .isoclaude/ directory. Stops at $HOME and /.
project_root() {
    local dir="$PWD"
    while :; do
        if [ -d "$dir/.isoclaude" ]; then
            printf '%s\n' "$dir"
            return
        fi
        if [ "$dir" = "/" ] || [ "$dir" = "$HOME" ]; then
            return
        fi
        dir="$(dirname "$dir")"
    done
}

# Sync $1 to $2 only when contents differ (preserves mtime when unchanged,
# so docker's build cache isn't invalidated by no-op syncs).
_sync_if_diff() {
    if ! cmp -s "$1" "$2" 2>/dev/null; then
        cp "$1" "$2"
        return 0
    fi
    return 1
}

# Ensure $ISOCLAUDE_HOME contains Dockerfile.base and entrypoint.sh.
# When invoked from the repo (script_dir/../image exists) the repo wins,
# so edits to the source are picked up on the next run. After install the
# installer is the source of truth and we just verify the files are there.
ensure_iso_home() {
    mkdir -p "$ISOCLAUDE_HOME"
    local src
    src="$(script_dir)/../image"
    if [ -f "$src/Dockerfile.base" ] && [ -f "$src/entrypoint.sh" ]; then
        local synced=0
        _sync_if_diff "$src/Dockerfile.base" "$ISOCLAUDE_HOME/Dockerfile.base" && synced=1
        _sync_if_diff "$src/entrypoint.sh"   "$ISOCLAUDE_HOME/entrypoint.sh"   && synced=1
        [ "$synced" -eq 1 ] && log "synced $ISOCLAUDE_HOME from $src"
        return 0
    fi
    if [ ! -f "$ISOCLAUDE_HOME/Dockerfile.base" ] || [ ! -f "$ISOCLAUDE_HOME/entrypoint.sh" ]; then
        die "$ISOCLAUDE_HOME is missing image files and no dev source found; run install.sh"
    fi
    return 0
}

# Strip whitespace from a file's contents.
_read_trimmed() { tr -d '[:space:]' < "$1"; }

# Resolve the target claude version: project pin > global pin > npm latest.
# Side-effect: if no pin exists anywhere, query npm and write the global pin.
read_pin() {
    local proj v
    proj="$(project_root)"
    if [ -n "$proj" ] && [ -f "$proj/.isoclaude/claude-version" ]; then
        v="$(_read_trimmed "$proj/.isoclaude/claude-version")"
        [ -n "$v" ] || die "$proj/.isoclaude/claude-version is empty"
        printf '%s\n' "$v"
        return
    fi
    if [ -f "$ISOCLAUDE_HOME/claude-version" ]; then
        v="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
        [ -n "$v" ] || die "$ISOCLAUDE_HOME/claude-version is empty"
        printf '%s\n' "$v"
        return
    fi
    command -v npm >/dev/null 2>&1 \
        || die "no version pinned and 'npm' not on PATH to discover latest"
    log "no pin set, querying npm for latest $NPM_PACKAGE"
    v="$(npm view "$NPM_PACKAGE" version --silent 2>/dev/null)" \
        || die "failed to query npm for latest $NPM_PACKAGE"
    [ -n "$v" ] || die "npm returned empty version for $NPM_PACKAGE"
    printf '%s\n' "$v" > "$ISOCLAUDE_HOME/claude-version"
    log "wrote global pin: $v"
    printf '%s\n' "$v"
}

# Returns the version label of the base image, or empty if missing.
# Parses JSON rather than using --format because Apple's `container` CLI
# doesn't support --format on image inspect. JSON parsing works on both
# docker (root .Config.Labels) and Apple container (nested
# .variants[].config.config.Labels) via a recursive walk.
image_label_version() {
    local runtime="$1"
    "$runtime" image inspect "$ISOCLAUDE_BASE_IMAGE" 2>/dev/null | python3 -c '
import sys, json
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(0)
KEY = "isoclaude.claude_version"
def walk(obj):
    if isinstance(obj, dict):
        labels = obj.get("Labels") or obj.get("labels")
        if isinstance(labels, dict) and labels.get(KEY):
            return labels[KEY]
        for v in obj.values():
            r = walk(v)
            if r: return r
    elif isinstance(obj, list):
        for v in obj:
            r = walk(v)
            if r: return r
    return None
v = walk(data)
if v: print(v)
' 2>/dev/null || true
}

# Build the base image if missing or if its label doesn't match the target.
ensure_base_image() {
    local runtime="$1" target="$2" current
    current="$(image_label_version "$runtime")"
    if [ "$current" = "$target" ]; then
        return
    fi
    if [ -z "$current" ]; then
        log "building $ISOCLAUDE_BASE_IMAGE @ $target (first build, may take a minute)"
    else
        log "pin changed ($current -> $target), rebuilding $ISOCLAUDE_BASE_IMAGE"
    fi
    "$runtime" build \
        --build-arg "CLAUDE_VERSION=$target" \
        -t "$ISOCLAUDE_BASE_IMAGE" \
        -f "$ISOCLAUDE_HOME/Dockerfile.base" \
        "$ISOCLAUDE_HOME" \
        || die "image build failed"
}

# Appends to RUN_FLAGS in-place.
_add()        { RUN_FLAGS=( "${RUN_FLAGS[@]}" "$@" ); }
_add_mount()  { _add "-v" "$1"; }

compose_run_flags() {
    RUN_FLAGS=()
    _add "--rm"
    # Allocate interactive stdin / tty only when this shell actually has
    # them. Apple `container` errors with ENODEV if -t is requested without
    # a real tty, and docker just suppresses input echo unnecessarily.
    [ -t 0 ] && _add "-i"
    [ -t 1 ] && _add "-t"

    # Working dir: bind-mount $PWD at same path and CD there.
    _add_mount "$PWD:$PWD"
    _add "-w" "$PWD"

    # Auth/credentials (rw so login persists).
    _add_mount "$HOME/.claude:/home/claude/.claude"

    # Git config (ro).
    if [ -f "$HOME/.gitconfig" ]; then
        _add_mount "$HOME/.gitconfig:/home/claude/.gitconfig:ro"
    else
        warn "$HOME/.gitconfig not found; commits inside the sandbox won't have your name/email"
    fi

    # SSH (ro).
    if [ -d "$HOME/.ssh" ]; then
        _add_mount "$HOME/.ssh:/home/claude/.ssh:ro"
    else
        warn "$HOME/.ssh not found; git push over ssh won't work from the sandbox"
    fi

    # Env: UID/GID for the entrypoint, plus terminal hints.
    _add "-e" "HOST_UID=$(id -u)"
    _add "-e" "HOST_GID=$(id -g)"
    _add "-e" "TERM"
    _add "-e" "COLORTERM"

    # Project-level overlays: env-files and extra mounts. local/ overrides
    # the committed copy by being listed second (docker takes later values).
    if [ -n "${PROJECT_ROOT:-}" ]; then
        local d="$PROJECT_ROOT/.isoclaude"
        [ -f "$d/env"       ] && _add "--env-file" "$d/env"
        [ -f "$d/local/env" ] && _add "--env-file" "$d/local/env"
        _add_project_mounts "$d/mounts"
        _add_project_mounts "$d/local/mounts"
    fi
}

# Read a mounts file, one spec per line, format: /host:/container[:ro|:rw].
# Skips comments and blank lines, expands a leading ~ in the host path.
_add_project_mounts() {
    local file="$1" line host rest
    [ -f "$file" ] || return 0
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line#"${line%%[![:space:]]*}"}"
        case "$line" in ""|"#"*) continue ;; esac
        case "$line" in
            *:*) ;;
            *)   warn "skipping invalid mount line in $file: $line"; continue ;;
        esac
        host="${line%%:*}"
        rest="${line#*:}"
        case "$host" in
            "~")    host="$HOME" ;;
            "~/"*)  host="$HOME/${host#\~/}" ;;
        esac
        _add_mount "$host:$rest"
    done < "$file"
}

# Exec the given entry command (claude, bash, ...) inside the sandbox.
# Uses RUN_IMAGE (the project overlay if one exists, otherwise the base).
# Honors ISOCLAUDE_DRY_RUN to print the runtime invocation without execing.
_exec_in_sandbox() {
    local runtime="$1" entry="$2"; shift 2
    compose_run_flags
    local image="${RUN_IMAGE:-$ISOCLAUDE_BASE_IMAGE}"
    if [ -n "${ISOCLAUDE_DRY_RUN:-}" ]; then
        printf '%s' "$runtime run"
        printf ' %q' "${RUN_FLAGS[@]}" "$image" "$entry" "$@"
        printf '\n'
        return 0
    fi
    exec "$runtime" run "${RUN_FLAGS[@]}" "$image" "$entry" "$@"
}

# Build the per-project image when .isoclaude/Dockerfile exists with a
# real FROM line. Tagged by content hash so changes get a fresh image
# automatically. Sets RUN_IMAGE on success.
ensure_project_image() {
    local runtime="$1" proj="$2"
    local dockerfile="$proj/.isoclaude/Dockerfile"
    [ -f "$dockerfile" ] || return 0
    # Skip silently if the file has no FROM line yet (init scaffold).
    grep -qE '^FROM[[:space:]]' "$dockerfile" || return 0
    # Enforce the only legal base.
    grep -qE '^FROM[[:space:]]+isoclaude-base:latest([[:space:]]|$)' "$dockerfile" \
        || die "$dockerfile: project images must FROM isoclaude-base:latest"

    local hash img
    hash="$(_file_hash "$dockerfile")"
    img="isoclaude-project-${hash}:latest"

    # If the tagged image already exists, no rebuild needed.
    if "$runtime" image inspect "$img" >/dev/null 2>&1; then
        RUN_IMAGE="$img"
        return 0
    fi

    log "building project image $img"
    "$runtime" build \
        -t "$img" \
        -f "$dockerfile" \
        "$proj/.isoclaude" \
        || die "project image build failed"
    RUN_IMAGE="$img"
}

# First 12 chars of sha256(file). Uses whichever of shasum/sha256sum is present.
_file_hash() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | cut -c1-12
    else
        shasum -a 256 "$1" | cut -c1-12
    fi
}

# Resolve runtime + pin + project_root + ensure both base and (optional)
# project images are built. Sets RUNTIME, PIN, PROJECT_ROOT, RUN_IMAGE.
_prepare() {
    RUNTIME="$(detect_runtime)"
    ensure_iso_home
    PROJECT_ROOT="$(project_root)"
    PIN="$(read_pin)"
    ensure_base_image "$RUNTIME" "$PIN"
    RUN_IMAGE="$ISOCLAUDE_BASE_IMAGE"
    if [ -n "$PROJECT_ROOT" ]; then
        ensure_project_image "$RUNTIME" "$PROJECT_ROOT"
    fi
}

cmd_run() {
    _prepare
    if [ "${YOLO:-0}" = "1" ]; then
        log "yolo: passing --dangerously-skip-permissions to claude"
        _exec_in_sandbox "$RUNTIME" claude --dangerously-skip-permissions "$@"
    else
        _exec_in_sandbox "$RUNTIME" claude "$@"
    fi
}

cmd_shell() {
    _prepare
    _exec_in_sandbox "$RUNTIME" bash "$@"
}

cmd_init() {
    local dir="$PWD/.isoclaude"
    if [ -d "$dir" ]; then
        log "$dir already exists; only creating any missing files"
    fi
    mkdir -p "$dir/local"

    _scaffold "$dir/Dockerfile" <<'EOF'
# Optional: extend the isoclaude base image with project-specific tools.
# Uncomment, edit, and re-run `isoclaude build` to pick up changes.
#
# FROM isoclaude-base:latest
# USER root
# RUN apt-get update && apt-get install -y --no-install-recommends \
#         python3 python3-pip \
#  && rm -rf /var/lib/apt/lists/*
# USER claude
EOF

    _scaffold "$dir/env" <<'EOF'
# KEY=VALUE lines passed into the sandbox as env vars. `#` comments OK.
# Put per-developer overrides in local/env (gitignored).
#
# EXAMPLE_API_KEY=...
EOF

    _scaffold "$dir/mounts" <<'EOF'
# Extra bind mounts, one spec per line. `~` is expanded host-side. `#` comments OK.
# Format: /host/path:/container/path[:ro]
# Put per-developer mounts in local/mounts (gitignored).
#
# ~/.cache/pip:/home/claude/.cache/pip
EOF

    _scaffold "$dir/.gitignore" <<'EOF'
local/
EOF

    _scaffold "$dir/local/.gitkeep" <<'EOF'
EOF

    log "initialized $dir"
    log "next: edit Dockerfile/env/mounts as needed, then run isoclaude"
}

# Write file with the given content from stdin only if it doesn't exist.
_scaffold() {
    local path="$1"
    if [ -e "$path" ]; then
        log "  skip (exists): ${path#$PWD/}"
        cat >/dev/null  # drain stdin
    else
        cat > "$path"
        log "  wrote:        ${path#$PWD/}"
    fi
}

cmd_build() {
    RUNTIME="$(detect_runtime)"
    ensure_iso_home
    PROJECT_ROOT="$(project_root)"
    PIN="$(read_pin)"
    log "force rebuild of $ISOCLAUDE_BASE_IMAGE @ $PIN"
    "$RUNTIME" image rm "$ISOCLAUDE_BASE_IMAGE" >/dev/null 2>&1 || true
    ensure_base_image "$RUNTIME" "$PIN"
    if [ -n "$PROJECT_ROOT" ] && [ -f "$PROJECT_ROOT/.isoclaude/Dockerfile" ] \
            && grep -qE '^FROM[[:space:]]' "$PROJECT_ROOT/.isoclaude/Dockerfile"; then
        local hash img
        hash="$(_file_hash "$PROJECT_ROOT/.isoclaude/Dockerfile")"
        img="isoclaude-project-${hash}:latest"
        "$RUNTIME" image rm "$img" >/dev/null 2>&1 || true
        ensure_project_image "$RUNTIME" "$PROJECT_ROOT"
    fi
    log "build complete"
}

cmd_version() {
    local runtime proj global_pin project_pin image_v latest
    runtime="$(detect_runtime 2>/dev/null || true)"
    proj="$(project_root)"

    if [ -f "$ISOCLAUDE_HOME/claude-version" ]; then
        global_pin="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
    fi
    if [ -n "$proj" ] && [ -f "$proj/.isoclaude/claude-version" ]; then
        project_pin="$(_read_trimmed "$proj/.isoclaude/claude-version")"
    fi
    if [ -n "$runtime" ]; then
        image_v="$(image_label_version "$runtime")"
    fi
    if command -v npm >/dev/null 2>&1; then
        latest="$(npm view "$NPM_PACKAGE" version --silent 2>/dev/null || true)"
    fi

    printf 'global pin:    %s\n' "${global_pin:-<unset>}"
    printf 'project pin:   %s\n' "${project_pin:-<unset>}"
    printf 'image label:   %s\n' "${image_v:-<not built>}"
    printf 'latest on npm: %s\n' "${latest:-<unknown>}"
    if [ -n "$proj" ]; then
        printf 'project root:  %s\n' "$proj"
        if [ -f "$proj/.isoclaude/Dockerfile" ] \
                && grep -qE '^FROM[[:space:]]' "$proj/.isoclaude/Dockerfile"; then
            local phash pimg pbuilt="no"
            phash="$(_file_hash "$proj/.isoclaude/Dockerfile")"
            pimg="isoclaude-project-${phash}:latest"
            if [ -n "$runtime" ] && "$runtime" image inspect "$pimg" >/dev/null 2>&1; then
                pbuilt="yes"
            fi
            printf 'project image: %s (built: %s)\n' "$pimg" "$pbuilt"
        fi
    fi
    printf 'runtime:       %s\n' "${runtime:-<none found>}"
}

cmd_update() {
    if [ "${1:-}" = "--check" ]; then
        ensure_iso_home
        local global latest
        [ -f "$ISOCLAUDE_HOME/claude-version" ] \
            && global="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
        command -v npm >/dev/null 2>&1 || die "'npm' not on PATH"
        latest="$(npm view "$NPM_PACKAGE" version --silent 2>/dev/null)" \
            || die "failed to query npm"
        printf 'current global pin: %s\n' "${global:-<unset>}"
        printf 'latest on npm:      %s\n' "$latest"
        if [ "$global" = "$latest" ]; then
            printf 'up to date.\n'
        else
            printf 'run `isoclaude update` to bump.\n'
        fi
        return
    fi

    local version="${1:-}"
    ensure_iso_home
    if [ -z "$version" ]; then
        command -v npm >/dev/null 2>&1 || die "'npm' not on PATH; pass a version explicitly"
        log "querying npm for latest $NPM_PACKAGE"
        version="$(npm view "$NPM_PACKAGE" version --silent 2>/dev/null)" \
            || die "failed to query npm"
    fi
    printf '%s\n' "$version" > "$ISOCLAUDE_HOME/claude-version"
    log "global pin set to $version"

    local runtime
    runtime="$(detect_runtime)"
    ensure_base_image "$runtime" "$version"
}

cmd_pin() {
    local version="${1:-}" proj
    ensure_iso_home
    proj="$(project_root)"
    if [ -z "$proj" ]; then
        proj="$PWD"
        log "no .isoclaude/ found above $PWD; creating one at $proj"
        mkdir -p "$proj/.isoclaude"
    fi

    if [ -z "$version" ]; then
        if [ ! -f "$ISOCLAUDE_HOME/claude-version" ]; then
            die "no global pin set; pass a version explicitly"
        fi
        version="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
    fi

    printf '%s\n' "$version" > "$proj/.isoclaude/claude-version"
    log "project pin set to $version at $proj/.isoclaude/claude-version"

    local runtime
    runtime="$(detect_runtime)"
    ensure_base_image "$runtime" "$version"
}

cmd_help() {
    cat <<'EOF'
isoclaude — run Claude Code in a sandboxed container.

USAGE
    isoclaude [SUBCOMMAND] [ARGS...]

DEFAULT
    With no subcommand (or with `run`), launches claude in the sandbox
    with PWD mounted plus ~/.claude (rw), ~/.gitconfig (ro), and ~/.ssh
    (ro). Args after `run` (or after `--`) are passed to claude.

SUBCOMMANDS
    run [ARGS]              Explicit form of the default.
    shell [ARGS]            Launch a bash shell in the sandbox.
    init                    Scaffold .isoclaude/ in the current dir.
    build                   Force-rebuild the base image at the current pin.
    version                 Show global pin, project pin, image label,
                            npm latest, project root, runtime.
    update [VERSION]        Update global pin to VERSION (default: npm
                            latest) and rebuild.
    update --check          Compare global pin to npm latest, no changes.
    pin [VERSION]           Set per-project pin to VERSION (default:
                            current global pin) and rebuild.
    help                    Show this message.

GLOBAL FLAGS
    --yolo, -Y              Pass --dangerously-skip-permissions to claude,
                            so it stops asking for permission on every
                            tool call. The sandbox is your safety net.
                            Only affects `run` (the default); ignored by
                            other subcommands. Strippable from anywhere
                            in the args.

ENVIRONMENT
    ISOCLAUDE_HOME           Override the install dir (default: ~/.isoclaude).
    ISOCLAUDE_RUNTIME        Force a specific runtime (e.g. docker, container).
    ISOCLAUDE_BASE_IMAGE     Override base image tag.
    ISOCLAUDE_DRY_RUN=1      Print the runtime invocation; don't exec.
    ISOCLAUDE_YOLO=1         Same as passing --yolo on every invocation.
EOF
}

main() {
    # Scan for global flags (currently just --yolo / -Y), strip them, and
    # remember in YOLO. Order-independent: works whether the flag comes
    # before a subcommand, after it, or stands alone.
    YOLO="${ISOCLAUDE_YOLO:-0}"
    local args=() arg
    for arg in "$@"; do
        case "$arg" in
            --yolo|-Y) YOLO=1 ;;
            *)         args+=("$arg") ;;
        esac
    done
    set -- "${args[@]}"

    case "${1:-}" in
        run)            shift; cmd_run "$@" ;;
        shell)          shift; cmd_shell "$@" ;;
        init)           shift; cmd_init "$@" ;;
        build)          shift; cmd_build "$@" ;;
        version)        shift; cmd_version "$@" ;;
        update)         shift; cmd_update "$@" ;;
        pin)            shift; cmd_pin "$@" ;;
        help|-h|--help) cmd_help ;;
        --)             shift; cmd_run "$@" ;;
        "")             cmd_run ;;
        *)              cmd_run "$@" ;;
    esac
}

# Only run main when executed directly, not when sourced (for tests).
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
