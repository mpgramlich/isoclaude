#!/usr/bin/env bash
# isoclaude — run Claude Code in a sandboxed container.
#
# Phase 2 surface: default run path only. Subcommands (init/update/pin/
# version/shell/build) are added in Phase 3, project-level config overlays
# in Phase 4, and the installer in Phase 5.
#
# Compatible with bash 3.2 (macOS default). Avoids mapfile, lone arr[@]
# under set -u, etc.

set -eo pipefail

if [ -z "${HOME:-}" ]; then
    printf '\033[31misoclaude:\033[0m HOME is not set; isoclaude needs it for state, auth, and mount targets\n' >&2
    exit 1
fi
ISOCLAUDE_HOME="${ISOCLAUDE_HOME:-$HOME/.isoclaude}"
ISOCLAUDE_BASE_IMAGE="${ISOCLAUDE_BASE_IMAGE:-isoclaude-base:latest}"
NPM_PACKAGE="@anthropic-ai/claude-code"

# Globals populated by compose_*; consumed by run_default.
RUN_FLAGS=()

log()  { printf '\033[2misoclaude:\033[0m %s\n' "$*" >&2; }
warn() { printf '\033[33misoclaude:\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[31misoclaude:\033[0m %s\n' "$*" >&2; exit 1; }

script_dir() {
    # Resolve $0 through any symlinks to find the script's real dir.
    local src="${BASH_SOURCE[0]}" dir
    while [ -L "$src" ]; do
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        case "$src" in /*) ;; *) src="$dir/$src" ;; esac
    done
    cd -P "$(dirname "$src")" && pwd
}

detect_runtime() {
    if [ -n "${ISOCLAUDE_RUNTIME:-}" ]; then
        command -v "$ISOCLAUDE_RUNTIME" >/dev/null 2>&1 \
            || die "ISOCLAUDE_RUNTIME=$ISOCLAUDE_RUNTIME not on PATH"
        printf '%s\n' "$ISOCLAUDE_RUNTIME"
        return
    fi
    local r
    for r in container orb docker podman; do
        if command -v "$r" >/dev/null 2>&1; then
            printf '%s\n' "$r"
            return
        fi
    done
    die "no container runtime found (looked for: container, orb, docker, podman)"
}

# Walk up from PWD looking for a .isoclaude/ directory. Stops at $HOME and /.
# Treats $HOME itself as off-limits: $HOME/.isoclaude is reserved for the
# wrapper's global config dir (the default ISOCLAUDE_HOME). When the user
# overrides ISOCLAUDE_HOME to a different path, $HOME/.isoclaude might no
# longer match — but we still don't want to surface it as a "project" since
# that's never what the user means.
project_root() {
    local dir="$PWD"
    while :; do
        if [ "$dir" = "$HOME" ]; then
            return  # $HOME is reserved, not a project root
        fi
        if [ -d "$dir/.isoclaude" ] && [ "$dir/.isoclaude" != "$ISOCLAUDE_HOME" ]; then
            printf '%s\n' "$dir"
            return
        fi
        if [ "$dir" = "/" ]; then
            return
        fi
        dir="$(dirname "$dir")"
    done
}

# Sync $1 to $2 only when contents differ (preserves mtime when unchanged,
# so docker's build cache isn't invalidated by no-op syncs).
_sync_if_diff() {
    if ! cmp -s "$1" "$2" 2>/dev/null; then
        cp "$1" "$2"
        return 0
    fi
    return 1
}

# Ensure $ISOCLAUDE_HOME contains Dockerfile.base and entrypoint.sh.
# When invoked from the repo (script_dir/../image exists) the repo wins,
# so edits to the source are picked up on the next run. After install the
# installer is the source of truth and we just verify the files are there.
ensure_iso_home() {
    mkdir -p "$ISOCLAUDE_HOME"
    local src
    src="$(script_dir)/../image"
    if [ -f "$src/Dockerfile.base" ] && [ -f "$src/entrypoint.sh" ]; then
        local synced=0
        _sync_if_diff "$src/Dockerfile.base" "$ISOCLAUDE_HOME/Dockerfile.base" && synced=1
        _sync_if_diff "$src/entrypoint.sh"   "$ISOCLAUDE_HOME/entrypoint.sh"   && synced=1
        [ "$synced" -eq 1 ] && log "synced $ISOCLAUDE_HOME from $src"
        return 0
    fi
    if [ ! -f "$ISOCLAUDE_HOME/Dockerfile.base" ] || [ ! -f "$ISOCLAUDE_HOME/entrypoint.sh" ]; then
        die "$ISOCLAUDE_HOME is missing image files and no dev source found; run install.sh"
    fi
    return 0
}

# Strip whitespace from a file's contents.
_read_trimmed() { tr -d '[:space:]' < "$1"; }

# Resolve the target claude version: project pin > global pin > npm latest.
# Side-effect: if no pin exists anywhere, query npm and write the global pin.
read_pin() {
    local proj v
    proj="$(project_root)"
    if [ -n "$proj" ] && [ -f "$proj/.isoclaude/claude-version" ]; then
        v="$(_read_trimmed "$proj/.isoclaude/claude-version")"
        [ -n "$v" ] || die "$proj/.isoclaude/claude-version is empty"
        printf '%s\n' "$v"
        return
    fi
    if [ -f "$ISOCLAUDE_HOME/claude-version" ]; then
        v="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
        [ -n "$v" ] || die "$ISOCLAUDE_HOME/claude-version is empty"
        printf '%s\n' "$v"
        return
    fi
    command -v npm >/dev/null 2>&1 \
        || die "no version pinned and 'npm' not on PATH to discover latest"
    log "no pin set, querying npm for latest $NPM_PACKAGE"
    v="$(npm view "$NPM_PACKAGE" version --silent 2>/dev/null)" \
        || die "failed to query npm for latest $NPM_PACKAGE"
    [ -n "$v" ] || die "npm returned empty version for $NPM_PACKAGE"
    printf '%s\n' "$v" > "$ISOCLAUDE_HOME/claude-version"
    log "wrote global pin: $v"
    printf '%s\n' "$v"
}

# Returns the version label of the base image, or empty if missing.
# Parses JSON rather than using --format because Apple's `container` CLI
# doesn't support --format on image inspect. JSON parsing works on both
# docker (root .Config.Labels) and Apple container (nested
# .variants[].config.config.Labels) via a recursive walk.
image_label_version() {
    local runtime="$1"
    "$runtime" image inspect "$ISOCLAUDE_BASE_IMAGE" 2>/dev/null | python3 -c '
import sys, json
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(0)
KEY = "isoclaude.claude_version"
def walk(obj):
    if isinstance(obj, dict):
        labels = obj.get("Labels") or obj.get("labels")
        if isinstance(labels, dict) and labels.get(KEY):
            return labels[KEY]
        for v in obj.values():
            r = walk(v)
            if r: return r
    elif isinstance(obj, list):
        for v in obj:
            r = walk(v)
            if r: return r
    return None
v = walk(data)
if v: print(v)
' 2>/dev/null || true
}

# Build the base image if missing or if its label doesn't match the target.
ensure_base_image() {
    local runtime="$1" target="$2" current
    current="$(image_label_version "$runtime")"
    if [ "$current" = "$target" ]; then
        return
    fi
    if [ -z "$current" ]; then
        log "building $ISOCLAUDE_BASE_IMAGE @ $target (first build, may take a minute)"
    else
        log "pin changed ($current -> $target), rebuilding $ISOCLAUDE_BASE_IMAGE"
    fi
    "$runtime" build \
        --build-arg "CLAUDE_VERSION=$target" \
        -t "$ISOCLAUDE_BASE_IMAGE" \
        -f "$ISOCLAUDE_HOME/Dockerfile.base" \
        "$ISOCLAUDE_HOME" \
        || die "image build failed"
}

# Appends to RUN_FLAGS in-place.
_add()        { RUN_FLAGS=( "${RUN_FLAGS[@]}" "$@" ); }
_add_mount()  { _add "-v" "$1"; }

compose_run_flags() {
    RUN_FLAGS=()
    _add "--rm"
    # Pass -i when stdin actually has something to forward — terminal,
    # pipe, or a non-empty regular file (heredoc). Without this gate,
    # claude inside waits ~3s for stdin data that will never come when
    # we were invoked from a background subprocess (stdin = socket or
    # /dev/null). With this gate, piped/heredoc input still reaches the
    # container.
    # -t is gated on stdout being a real TTY because Apple `container`
    # errors with ENODEV if -t is requested without one.
    if [ -t 0 ] || [ -p /dev/stdin ] || [ -s /dev/stdin ]; then
        _add "-i"
    fi
    [ -t 1 ] && _add "-t"

    # Working dir: bind-mount $PWD at same path and CD there. Refuse PWD=/
    # outright — mounting / over the container's rootfs breaks /proc, /dev,
    # /sys (Apple container errors with a fairly cryptic mount errno 30).
    if [ "$PWD" = "/" ]; then
        die "isoclaude refuses to run with PWD=/ (would overlay the container's rootfs); cd to a subdirectory first"
    fi
    # Refuse PWD containing ':' — it's the separator in `-v src:dst` so
    # the runtime would misparse the bind spec. (A future move to docker's
    # --mount type=bind,source=...,target=... syntax would lift this.)
    case "$PWD" in
        *:*) die "isoclaude doesn't support a working directory whose path contains ':' (would break -v src:dst parsing)" ;;
    esac
    _add_mount "$PWD:$PWD"
    _add "-w" "$PWD"

    # Auth/credentials (rw so login persists). Claude stores all of:
    #   ~/.claude/                       session history, projects, backups
    #   ~/.claude.json                   the actual config (incl. settings)
    #   ~/.claude/.credentials.json      OAuth tokens, on Linux installs and
    #                                    on macOS installs after sync-auth.
    # macOS native installs keep credentials in the keychain instead; see
    # _maybe_warn_macos_auth below.
    # Create ~/.claude on demand. Without it the bind mount fails on
    # runtimes that don't auto-create the source ("path does not exist"
    # on Apple container), and the in-container claude has no place to
    # save session state. Idempotent if the dir already exists.
    mkdir -p "$HOME/.claude" 2>/dev/null || true
    if [ -d "$HOME/.claude" ]; then
        _add_mount "$HOME/.claude:/home/claude/.claude"
    else
        warn "$HOME/.claude could not be created; session state won't persist"
    fi
    if [ -f "$HOME/.claude.json" ]; then
        _add_mount "$HOME/.claude.json:/home/claude/.claude.json"
    else
        warn "$HOME/.claude.json not found; the in-container claude will need /login on first run"
    fi
    _macos_auth_check

    # Git config (ro).
    if [ -f "$HOME/.gitconfig" ]; then
        _add_mount "$HOME/.gitconfig:/home/claude/.gitconfig:ro"
    else
        warn "$HOME/.gitconfig not found; commits inside the sandbox won't have your name/email"
    fi

    # SSH (ro).
    if [ -d "$HOME/.ssh" ]; then
        _add_mount "$HOME/.ssh:/home/claude/.ssh:ro"
    else
        warn "$HOME/.ssh not found; git push over ssh won't work from the sandbox"
    fi

    # Env: UID/GID for the entrypoint, plus terminal hints.
    _add "-e" "HOST_UID=$(id -u)"
    _add "-e" "HOST_GID=$(id -g)"
    _add "-e" "TERM"
    _add "-e" "COLORTERM"

    # Project-level overlays: env vars and extra mounts. local/ overrides
    # the committed copy by being listed second (docker takes later -e).
    if [ -n "${PROJECT_ROOT:-}" ]; then
        local d="$PROJECT_ROOT/.isoclaude"
        _add_project_env "$d/env"
        _add_project_env "$d/local/env"
        _add_project_mounts "$d/mounts"
        _add_project_mounts "$d/local/mounts"
    fi

    # MCP servers configured at the user or project level: parse their
    # `command` paths and bind-mount each parent dir so the in-container
    # claude can spawn the same MCP servers as the host.
    _add_mcp_mounts
}

# Read a KEY=VALUE env file and add each entry as `-e KEY=VALUE`. We parse
# the file ourselves (rather than using --env-file) because runtime
# parsers vary in strictness — Apple container fails the entire run with
# "no variable name on line '=foo'" instead of skipping it. Doing the
# parsing here lets us warn cleanly and keep going.
_add_project_env() {
    local file="$1" line trimmed
    [ -f "$file" ] || return 0
    while IFS= read -r line || [ -n "$line" ]; do
        # Strip a trailing \r (CRLF-edited files from Windows would
        # otherwise leak a \r into every env value).
        line="${line%$'\r'}"
        # Strip leading whitespace; skip blanks and comments.
        trimmed="${line#"${line%%[![:space:]]*}"}"
        case "$trimmed" in
            ""|"#"*) continue ;;
            =*)
                warn "$file: skipping line with empty key: $line"
                continue ;;
            *=*)
                _add "-e" "$trimmed"
                ;;
            *)
                warn "$file: skipping line without '=': $line"
                continue ;;
        esac
    done < "$file"
}

# Discover MCP server commands from .mcp.json (project) and ~/.claude.json
# (user) and add ro bind-mounts for each command's parent dir, so the in-
# container claude can spawn the same servers as the host. Skips paths
# under system dirs whose bind-mount would shadow the container's
# infrastructure (/usr, /bin, /sbin, /lib*, /etc, /var, /proc, /sys, /dev).
# Dedupes; skips paths already covered by $PWD or ~/.claude. Idempotent.
_add_mcp_mounts() {
    local sources=()
    [ -f "$HOME/.claude.json" ] && sources+=("$HOME/.claude.json")

    # Find the nearest .mcp.json by walking up from PWD (matches claude).
    local dir="$PWD"
    while :; do
        if [ -f "$dir/.mcp.json" ]; then
            sources+=("$dir/.mcp.json")
            break
        fi
        if [ "$dir" = "/" ] || [ "$dir" = "$HOME" ]; then break; fi
        dir="$(dirname "$dir")"
    done

    [ "${#sources[@]}" -eq 0 ] && return 0

    # Python3 is the JSON parser we already use. Emits unique parent dirs
    # (stdout, one per line) and warnings (stderr) for skipped system paths.
    local mounts
    mounts=$(python3 - "${sources[@]}" <<'PY'
import sys, os, json
UNSAFE = ("/bin", "/sbin", "/lib", "/lib32", "/lib64",
          "/etc", "/usr", "/var", "/proc", "/sys", "/dev")
def is_unsafe(p):
    if p in UNSAFE:
        return True
    for u in UNSAFE:
        if p.startswith(u + "/"):
            return True
    return False
covered = set()
pwd = os.environ.get("PWD")
home = os.environ.get("HOME", "")
if pwd: covered.add(pwd)
if home: covered.add(os.path.join(home, ".claude"))
seen = set()
for src in sys.argv[1:]:
    try:
        with open(src) as f:
            data = json.load(f)
    except Exception:
        continue
    servers = data.get("mcpServers")
    if not isinstance(servers, dict):
        continue
    for name, cfg in servers.items():
        if not isinstance(cfg, dict):
            continue
        cmd = cfg.get("command")
        if not isinstance(cmd, str) or not cmd.startswith("/"):
            continue
        if not os.path.exists(cmd):
            continue
        parent = os.path.dirname(cmd) or "/"
        if any(parent == d or parent.startswith(d + "/") for d in covered):
            continue
        if is_unsafe(parent):
            sys.stderr.write(
                "isoclaude: skipping MCP system path (would shadow container): "
                f"{parent} (server '{name}')\n")
            continue
        if parent not in seen:
            seen.add(parent)
            print(parent)
PY
)

    local d
    while IFS= read -r d || [ -n "$d" ]; do
        [ -z "$d" ] && continue
        log "binding MCP server dir: $d"
        _add_mount "$d:$d:ro"
    done <<< "$mounts"
}

# Read a mounts file, one spec per line, format: /host:/container[:ro|:rw].
# Skips comments and blank lines, expands a leading ~ in the host path.
_add_project_mounts() {
    local file="$1" line host rest
    [ -f "$file" ] || return 0
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%$'\r'}"
        line="${line#"${line%%[![:space:]]*}"}"
        case "$line" in ""|"#"*) continue ;; esac
        case "$line" in
            *:*) ;;
            *)   warn "skipping invalid mount line in $file: $line"; continue ;;
        esac
        host="${line%%:*}"
        rest="${line#*:}"
        case "$host" in
            "~")    host="$HOME" ;;
            "~/"*)  host="$HOME/${host#\~/}" ;;
        esac
        # Pre-check: runtime errors with a cryptic message if the host
        # path doesn't exist. Warn loudly and skip — silently dropping a
        # mount the user asked for would hide a real problem.
        if [ ! -e "$host" ]; then
            warn "$file: host path doesn't exist, skipping: $line"
            continue
        fi
        _add_mount "$host:$rest"
    done < "$file"
}

# Exec the given entry command (claude, bash, ...) inside the sandbox.
# Uses RUN_IMAGE (the project overlay if one exists, otherwise the base).
# Honors ISOCLAUDE_DRY_RUN to print the runtime invocation without execing.
_exec_in_sandbox() {
    local runtime="$1" entry="$2"; shift 2
    compose_run_flags
    local image="${RUN_IMAGE:-$ISOCLAUDE_BASE_IMAGE}"
    if [ -n "${ISOCLAUDE_DRY_RUN:-}" ]; then
        printf '%s' "$runtime run"
        printf ' %q' "${RUN_FLAGS[@]}" "$image" "$entry" "$@"
        printf '\n'
        return 0
    fi
    exec "$runtime" run "${RUN_FLAGS[@]}" "$image" "$entry" "$@"
}

# Build the per-project image when .isoclaude/Dockerfile exists with a
# real FROM line. Tagged by content hash so changes get a fresh image
# automatically. Sets RUN_IMAGE on success.
ensure_project_image() {
    local runtime="$1" proj="$2"
    local dockerfile="$proj/.isoclaude/Dockerfile"
    [ -f "$dockerfile" ] || return 0
    # Skip silently if the file has no FROM line yet (init scaffold).
    grep -qE '^FROM[[:space:]]' "$dockerfile" || return 0
    # Enforce the only legal base.
    grep -qE '^FROM[[:space:]]+isoclaude-base:latest([[:space:]]|$)' "$dockerfile" \
        || die "$dockerfile: project images must FROM isoclaude-base:latest"

    local hash img
    hash="$(_file_hash "$dockerfile")"
    img="isoclaude-project-${hash}:latest"

    # If the tagged image already exists, no rebuild needed.
    if "$runtime" image inspect "$img" >/dev/null 2>&1; then
        RUN_IMAGE="$img"
        return 0
    fi

    log "building project image $img"
    "$runtime" build \
        -t "$img" \
        -f "$dockerfile" \
        "$proj/.isoclaude" \
        || die "project image build failed"
    RUN_IMAGE="$img"
}

# First 12 chars of sha256(file). Uses whichever of shasum/sha256sum is present.
_file_hash() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | cut -c1-12
    else
        shasum -a 256 "$1" | cut -c1-12
    fi
}

# Resolve runtime + pin + project_root + ensure both base and (optional)
# project images are built. Sets RUNTIME, PIN, PROJECT_ROOT, RUN_IMAGE.
_prepare() {
    RUNTIME="$(detect_runtime)"
    ensure_iso_home
    PROJECT_ROOT="$(project_root)"
    PIN="$(read_pin)"
    ensure_base_image "$RUNTIME" "$PIN"
    RUN_IMAGE="$ISOCLAUDE_BASE_IMAGE"
    if [ -n "$PROJECT_ROOT" ]; then
        ensure_project_image "$RUNTIME" "$PROJECT_ROOT"
    fi
}

cmd_run() {
    _prepare
    if [ "${YOLO:-0}" = "1" ]; then
        log "yolo: passing --dangerously-skip-permissions to claude"
        _exec_in_sandbox "$RUNTIME" claude --dangerously-skip-permissions "$@"
    else
        _exec_in_sandbox "$RUNTIME" claude "$@"
    fi
}

# Bridge the macOS keychain credential into a file the container can read.
# Silent when ~/.claude/.credentials.json already matches the keychain
# (the common case after the first sync). Logs only on actual change.
# Returns:
#   0 — file is now in sync with keychain (either was already, or refreshed)
#   1 — keychain has no claude credential AND no file exists
#   2 — non-macOS / no security CLI (caller should silently skip)
_macos_auth_refresh() {
    [ "$(uname 2>/dev/null)" = "Darwin" ] || return 2
    command -v security >/dev/null 2>&1   || return 2

    local target="$HOME/.claude/.credentials.json" cur
    cur=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) \
        || cur=""

    if [ -z "$cur" ]; then
        # Keychain is empty. We leave any existing file alone (host might be
        # logged out temporarily; better to keep stale auth than break the
        # container outright). Caller decides whether to warn.
        [ -f "$target" ] && return 0 || return 1
    fi

    if [ -f "$target" ] && [ "$(cat "$target")" = "$cur" ]; then
        return 0  # already current; silent
    fi

    mkdir -p "$HOME/.claude"
    # Write atomically: temp file + mv, so a concurrent read by the running
    # host claude never sees a half-written file.
    local tmp="$target.tmp.$$"
    printf '%s\n' "$cur" > "$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$target"
    log "refreshed ~/.claude/.credentials.json from macOS keychain"
    return 0
}

# Called from compose_run_flags. Refreshes credentials when possible; warns
# only when the user actually has nothing to authenticate with. The
# `|| rc=$?` keeps the function under set -e from tripping when
# _macos_auth_refresh's "no keychain on this platform" return (2) reaches
# us — which is the normal path on Linux.
_macos_auth_check() {
    local rc=0
    _macos_auth_refresh || rc=$?
    case "$rc" in
        1)  warn "no claude credentials found (host not logged in?)"
            warn "  run host \`claude /login\`, then this will auto-sync"
            ;;
    esac
}

# Bridge the macOS keychain credential to a file the container can read.
# Public, explicit version of _macos_auth_refresh — errors loudly when it
# can't do anything.
cmd_sync_auth() {
    [ "$(uname 2>/dev/null)" = "Darwin" ] \
        || die "sync-auth is only needed on macOS (other platforms store credentials on disk)"
    command -v security >/dev/null 2>&1 \
        || die "macOS \`security\` CLI not found"

    local rc=0
    _macos_auth_refresh || rc=$?
    case "$rc" in
        0)
            if [ -f "$HOME/.claude/.credentials.json" ]; then
                log "credentials at ~/.claude/.credentials.json are in sync with keychain"
            fi
            ;;
        1)
            die "no 'Claude Code-credentials' entry in keychain; run host claude /login first"
            ;;
        2)
            die "platform check failed (should not happen — file a bug)"
            ;;
    esac
}

cmd_shell() {
    _prepare
    _exec_in_sandbox "$RUNTIME" bash "$@"
}

cmd_init() {
    local dir="$PWD/.isoclaude"
    if [ -d "$dir" ]; then
        log "$dir already exists; only creating any missing files"
    fi
    mkdir -p "$dir/local"

    _scaffold "$dir/Dockerfile" <<'EOF'
# Optional: extend the isoclaude base image with project-specific tools.
# Uncomment, edit, and re-run `isoclaude build` to pick up changes.
#
# Don't set USER in this file — the base image's entrypoint runs briefly
# as root to remap UIDs to match your host, then drops to the `claude`
# user via gosu. A `USER claude` line here would shift the entrypoint to
# non-root and break the remap with "usermod: Permission denied".
#
# FROM isoclaude-base:latest
# RUN apt-get update && apt-get install -y --no-install-recommends \
#         python3 python3-pip \
#  && rm -rf /var/lib/apt/lists/*
EOF

    _scaffold "$dir/env" <<'EOF'
# KEY=VALUE lines passed into the sandbox as env vars. `#` comments OK.
# Put per-developer overrides in local/env (gitignored).
#
# EXAMPLE_API_KEY=...
EOF

    _scaffold "$dir/mounts" <<'EOF'
# Extra bind mounts, one spec per line. `~` is expanded host-side. `#` comments OK.
# Format: /host/path:/container/path[:ro]
# Put per-developer mounts in local/mounts (gitignored).
#
# ~/.cache/pip:/home/claude/.cache/pip
EOF

    _scaffold "$dir/.gitignore" <<'EOF'
local/
EOF

    _scaffold "$dir/local/.gitkeep" <<'EOF'
EOF

    log "initialized $dir"
    log "next: edit Dockerfile/env/mounts as needed, then run isoclaude"
}

# Write file with the given content from stdin only if it doesn't exist.
_scaffold() {
    local path="$1"
    if [ -e "$path" ]; then
        log "  skip (exists): ${path#$PWD/}"
        cat >/dev/null  # drain stdin
    else
        cat > "$path"
        log "  wrote:        ${path#$PWD/}"
    fi
}

cmd_build() {
    RUNTIME="$(detect_runtime)"
    ensure_iso_home
    PROJECT_ROOT="$(project_root)"
    PIN="$(read_pin)"
    log "force rebuild of $ISOCLAUDE_BASE_IMAGE @ $PIN"
    "$RUNTIME" image rm "$ISOCLAUDE_BASE_IMAGE" >/dev/null 2>&1 || true
    ensure_base_image "$RUNTIME" "$PIN"
    if [ -n "$PROJECT_ROOT" ] && [ -f "$PROJECT_ROOT/.isoclaude/Dockerfile" ] \
            && grep -qE '^FROM[[:space:]]' "$PROJECT_ROOT/.isoclaude/Dockerfile"; then
        local hash img
        hash="$(_file_hash "$PROJECT_ROOT/.isoclaude/Dockerfile")"
        img="isoclaude-project-${hash}:latest"
        "$RUNTIME" image rm "$img" >/dev/null 2>&1 || true
        ensure_project_image "$RUNTIME" "$PROJECT_ROOT"
    fi
    log "build complete"
}

cmd_version() {
    local runtime proj global_pin project_pin image_v latest
    runtime="$(detect_runtime 2>/dev/null || true)"
    proj="$(project_root)"

    if [ -f "$ISOCLAUDE_HOME/claude-version" ]; then
        global_pin="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
    fi
    if [ -n "$proj" ] && [ -f "$proj/.isoclaude/claude-version" ]; then
        project_pin="$(_read_trimmed "$proj/.isoclaude/claude-version")"
    fi
    if [ -n "$runtime" ]; then
        image_v="$(image_label_version "$runtime")"
    fi
    if command -v npm >/dev/null 2>&1; then
        latest="$(npm view "$NPM_PACKAGE" version --silent 2>/dev/null || true)"
    fi

    printf 'global pin:    %s\n' "${global_pin:-<unset>}"
    printf 'project pin:   %s\n' "${project_pin:-<unset>}"
    printf 'image label:   %s\n' "${image_v:-<not built>}"
    printf 'latest on npm: %s\n' "${latest:-<unknown>}"
    if [ -n "$proj" ]; then
        printf 'project root:  %s\n' "$proj"
        if [ -f "$proj/.isoclaude/Dockerfile" ] \
                && grep -qE '^FROM[[:space:]]' "$proj/.isoclaude/Dockerfile"; then
            local phash pimg pbuilt="no"
            phash="$(_file_hash "$proj/.isoclaude/Dockerfile")"
            pimg="isoclaude-project-${phash}:latest"
            if [ -n "$runtime" ] && "$runtime" image inspect "$pimg" >/dev/null 2>&1; then
                pbuilt="yes"
            fi
            printf 'project image: %s (built: %s)\n' "$pimg" "$pbuilt"
        fi
    fi
    printf 'runtime:       %s\n' "${runtime:-<none found>}"
}

cmd_update() {
    if [ "${1:-}" = "--check" ]; then
        ensure_iso_home
        local global latest
        [ -f "$ISOCLAUDE_HOME/claude-version" ] \
            && global="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
        command -v npm >/dev/null 2>&1 || die "'npm' not on PATH"
        latest="$(npm view "$NPM_PACKAGE" version --silent 2>/dev/null)" \
            || die "failed to query npm"
        printf 'current global pin: %s\n' "${global:-<unset>}"
        printf 'latest on npm:      %s\n' "$latest"
        if [ "$global" = "$latest" ]; then
            printf 'up to date.\n'
        else
            printf 'run `isoclaude update` to bump.\n'
        fi
        return
    fi

    local version="${1:-}"
    ensure_iso_home
    if [ -z "$version" ]; then
        command -v npm >/dev/null 2>&1 || die "'npm' not on PATH; pass a version explicitly"
        log "querying npm for latest $NPM_PACKAGE"
        version="$(npm view "$NPM_PACKAGE" version --silent 2>/dev/null)" \
            || die "failed to query npm"
    fi
    printf '%s\n' "$version" > "$ISOCLAUDE_HOME/claude-version"
    log "global pin set to $version"

    local runtime
    runtime="$(detect_runtime)"
    ensure_base_image "$runtime" "$version"
}

cmd_pin() {
    local version="${1:-}" proj
    ensure_iso_home
    proj="$(project_root)"
    if [ -z "$proj" ]; then
        proj="$PWD"
        log "no .isoclaude/ found above $PWD; creating one at $proj"
        mkdir -p "$proj/.isoclaude"
    fi

    if [ -z "$version" ]; then
        if [ ! -f "$ISOCLAUDE_HOME/claude-version" ]; then
            die "no global pin set; pass a version explicitly"
        fi
        version="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
    fi

    printf '%s\n' "$version" > "$proj/.isoclaude/claude-version"
    log "project pin set to $version at $proj/.isoclaude/claude-version"

    local runtime
    runtime="$(detect_runtime)"
    ensure_base_image "$runtime" "$version"
}

# List isoclaude images of the given type ("base" or "project") that exist
# in the runtime. Emits one "<name>:<tag>" per line. The image name appears
# alone in column 1 of `image list`; the tag is in column 2.
_list_isoclaude_images() {
    local runtime="$1" kind="$2" pat
    case "$kind" in
        base)    pat='^isoclaude-base$' ;;
        project) pat='^isoclaude-project-' ;;
        *)       die "internal: unknown image kind '$kind'" ;;
    esac
    "$runtime" image list 2>/dev/null \
        | awk -v p="$pat" '
            NR==1 { next }
            $1 ~ p {
                tag = ($2 == "" || $2 == "<none>") ? "latest" : $2
                print $1":"tag
            }'
}

cmd_prune() {
    local nuke_all=0
    case "${1:-}" in
        --all|-a) nuke_all=1 ;;
        "") ;;
        *) die "unknown arg to prune: $1" ;;
    esac

    local runtime current_hash="" img hash kept=0 removed=0
    runtime="$(detect_runtime)"

    # Identify the project's current Dockerfile hash so we don't evict the
    # image we're about to use (unless --all).
    if [ "$nuke_all" -eq 0 ]; then
        local proj
        proj="$(project_root)"
        if [ -n "$proj" ] && [ -f "$proj/.isoclaude/Dockerfile" ] \
                && grep -qE '^FROM[[:space:]]' "$proj/.isoclaude/Dockerfile"; then
            current_hash="$(_file_hash "$proj/.isoclaude/Dockerfile")"
        fi
    fi

    while IFS= read -r img; do
        [ -z "$img" ] && continue
        # img is like "isoclaude-project-<hash>:latest"
        hash="${img#isoclaude-project-}"
        hash="${hash%:*}"
        if [ -n "$current_hash" ] && [ "$hash" = "$current_hash" ]; then
            log "  keep:   $img (current project)"
            kept=$((kept + 1))
            continue
        fi
        "$runtime" image rm "$img" >/dev/null 2>&1 \
            && { log "  remove: $img"; removed=$((removed + 1)); } \
            || warn "  failed: $img"
    done <<<"$(_list_isoclaude_images "$runtime" project)"

    log "pruned $removed project image(s), kept $kept"
}

cmd_uninstall() {
    local purge=0 yes=0
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --purge)  purge=1 ;;
            --yes|-y) yes=1 ;;
            *) die "unknown arg to uninstall: $1" ;;
        esac
        shift
    done

    local self runtime
    self="$(_self_path)"
    runtime="$(detect_runtime 2>/dev/null || true)"

    printf 'will remove:\n'
    printf '  %s\n' "$self"
    [ -d "$ISOCLAUDE_HOME" ] && printf '  %s\n' "$ISOCLAUDE_HOME"
    if [ "$purge" -eq 1 ] && [ -n "$runtime" ]; then
        local img
        for img in $(_list_isoclaude_images "$runtime" base) \
                   $(_list_isoclaude_images "$runtime" project); do
            printf '  image: %s\n' "$img"
        done
    fi

    if [ "$yes" -eq 0 ]; then
        printf 'proceed? [y/N] '
        local ans
        read -r ans
        case "$ans" in
            y|Y|yes|YES) ;;
            *) log "cancelled"; return 0 ;;
        esac
    fi

    if [ "$purge" -eq 1 ] && [ -n "$runtime" ]; then
        local img
        for img in $(_list_isoclaude_images "$runtime" base) \
                   $(_list_isoclaude_images "$runtime" project); do
            "$runtime" image rm "$img" >/dev/null 2>&1 \
                && log "removed image $img" \
                || warn "couldn't remove $img"
        done
    fi

    [ -d "$ISOCLAUDE_HOME" ] && rm -rf "$ISOCLAUDE_HOME" && log "removed $ISOCLAUDE_HOME"

    # Self-removal: the kernel keeps the inode alive until this process
    # exits, so we can rm $self mid-flight without breaking the script.
    if [ -L "$self" ] || [ -f "$self" ]; then
        if rm "$self" 2>/dev/null; then
            log "removed $self"
        else
            warn "couldn't remove $self (try: sudo rm $self)"
        fi
    fi
    log "uninstalled"
}

# Best-effort path to this script, resolving symlinks like script_dir does.
_self_path() {
    local src="${BASH_SOURCE[0]}" dir
    while [ -L "$src" ]; do
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        case "$src" in /*) ;; *) src="$dir/$src" ;; esac
    done
    printf '%s\n' "$src"
}

# --- doctor ---

_doc_ok()   { printf '  \033[32m[ok]\033[0m   %s\n' "$*"; DOC_OK=$((DOC_OK + 1)); }
_doc_warn() { printf '  \033[33m[warn]\033[0m %s\n' "$*"; DOC_WARN=$((DOC_WARN + 1)); }
_doc_err()  { printf '  \033[31m[err]\033[0m  %s\n' "$*"; DOC_ERR=$((DOC_ERR + 1)); }
_doc_section() { printf '\n\033[1m%s\033[0m\n' "$1"; }
_doc_note()    { printf '         %s\n' "$1"; }

_doctor_runtime() {
    _doc_section "Runtime"
    local runtime=""
    if [ -n "${ISOCLAUDE_RUNTIME:-}" ]; then
        if command -v "$ISOCLAUDE_RUNTIME" >/dev/null 2>&1; then
            runtime="$ISOCLAUDE_RUNTIME"
            _doc_ok "ISOCLAUDE_RUNTIME=$runtime (forced)"
        else
            _doc_err "ISOCLAUDE_RUNTIME=$ISOCLAUDE_RUNTIME but not on PATH"
            return
        fi
    else
        local r
        for r in container orb docker podman; do
            command -v "$r" >/dev/null 2>&1 && { runtime="$r"; break; }
        done
        if [ -n "$runtime" ]; then
            _doc_ok "runtime detected: $runtime"
        else
            _doc_err "no container runtime on PATH (looked for: container, orb, docker, podman)"
            return
        fi
    fi
    if "$runtime" image list >/dev/null 2>&1; then
        _doc_ok "runtime reachable (\`$runtime image list\` works)"
    else
        _doc_err "$runtime is on PATH but \`$runtime image list\` failed (daemon not running?)"
    fi
}

_doctor_wrapper() {
    _doc_section "Wrapper"
    local self
    self="$(_self_path)"
    _doc_ok "wrapper at $self"
    local dir
    dir="$(dirname "$self")"
    case ":$PATH:" in
        *":$dir:"*) _doc_ok "wrapper dir on PATH" ;;
        *) _doc_warn "wrapper dir ($dir) is not on PATH; you'd need to invoke by full path" ;;
    esac
}

_doctor_pin_and_image() {
    _doc_section "Pin & image"
    if [ ! -f "$ISOCLAUDE_HOME/claude-version" ]; then
        _doc_warn "no global pin at $ISOCLAUDE_HOME/claude-version (will query npm on first run)"
        return
    fi
    local pin
    pin="$(_read_trimmed "$ISOCLAUDE_HOME/claude-version")"
    _doc_ok "global pin: $pin"

    local runtime
    runtime="$(detect_runtime 2>/dev/null || true)"
    [ -z "$runtime" ] && return

    local label
    label="$(image_label_version "$runtime")"
    if [ -z "$label" ]; then
        _doc_warn "base image not built yet (~2 min build on next run)"
    elif [ "$label" = "$pin" ]; then
        _doc_ok "base image: $ISOCLAUDE_BASE_IMAGE @ $label"
    else
        _doc_warn "base image label ($label) differs from pin ($pin); next run will rebuild"
    fi
}

_doctor_auth() {
    _doc_section "Auth & mounts"
    [ -d "$HOME/.claude" ]      && _doc_ok "~/.claude/ present"      || _doc_warn "~/.claude/ missing"
    [ -f "$HOME/.claude.json" ] && _doc_ok "~/.claude.json present" || _doc_warn "~/.claude.json missing — in-container claude will need /login"

    if [ "$(uname 2>/dev/null)" = "Darwin" ] && command -v security >/dev/null 2>&1; then
        local has_kc has_file
        has_kc=0; has_file=0
        security find-generic-password -s "Claude Code-credentials" >/dev/null 2>&1 && has_kc=1
        [ -f "$HOME/.claude/.credentials.json" ] && has_file=1

        if [ "$has_kc" = 1 ] && [ "$has_file" = 1 ]; then
            local kc_payload file_payload
            kc_payload=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null)
            file_payload=$(cat "$HOME/.claude/.credentials.json")
            if [ "$kc_payload" = "$file_payload" ]; then
                _doc_ok "macOS keychain ↔ ~/.claude/.credentials.json in sync"
            else
                _doc_warn "macOS keychain has different credentials than ~/.claude/.credentials.json"
                _doc_note "fix: run \`isoclaude sync-auth\` (or the next run will auto-refresh)"
            fi
        elif [ "$has_kc" = 1 ]; then
            _doc_warn "macOS keychain has credentials but ~/.claude/.credentials.json missing"
            _doc_note "fix: run \`isoclaude sync-auth\`"
        elif [ "$has_file" = 1 ]; then
            _doc_warn "~/.claude/.credentials.json exists but no keychain entry — host logged out?"
        else
            _doc_warn "no host login found (no keychain entry, no credentials file)"
            _doc_note "fix: run host \`claude /login\`, then \`isoclaude sync-auth\`"
        fi
    elif [ -f "$HOME/.claude/.credentials.json" ]; then
        _doc_ok "~/.claude/.credentials.json present"
    else
        _doc_warn "no claude credentials on disk; in-container claude will need /login"
    fi

    [ -f "$HOME/.gitconfig" ] && _doc_ok "~/.gitconfig present"      || _doc_warn "~/.gitconfig missing — commits in sandbox won't have your name/email"
    [ -d "$HOME/.ssh"      ] && _doc_ok "~/.ssh/ present"            || _doc_warn "~/.ssh/ missing — no git push over ssh from sandbox"
}

_doctor_project() {
    _doc_section "Project"
    local proj
    proj="$(project_root)"
    if [ -z "$proj" ]; then
        _doc_note "no .isoclaude/ found at or above $PWD (using base image, no overlays)"
        return
    fi
    _doc_ok "project root: $proj"

    if [ -f "$proj/.isoclaude/claude-version" ]; then
        _doc_ok "project pin: $(_read_trimmed "$proj/.isoclaude/claude-version")"
    fi
    [ -f "$proj/.isoclaude/env"    ] && _doc_ok ".isoclaude/env present"
    [ -f "$proj/.isoclaude/mounts" ] && _doc_ok ".isoclaude/mounts present"

    if [ -f "$proj/.isoclaude/Dockerfile" ] \
            && grep -qE '^FROM[[:space:]]' "$proj/.isoclaude/Dockerfile"; then
        local runtime hash img
        runtime="$(detect_runtime 2>/dev/null || true)"
        hash="$(_file_hash "$proj/.isoclaude/Dockerfile")"
        img="isoclaude-project-${hash}:latest"
        if [ -n "$runtime" ] && "$runtime" image inspect "$img" >/dev/null 2>&1; then
            _doc_ok "project image: $img (built)"
        else
            _doc_warn "project image $img not built yet (next run will build)"
        fi
    fi
}

cmd_doctor() {
    DOC_OK=0; DOC_WARN=0; DOC_ERR=0
    _doctor_runtime
    _doctor_wrapper
    _doctor_pin_and_image
    _doctor_auth
    _doctor_project

    printf '\n%d ok, %d warn, %d error\n' "$DOC_OK" "$DOC_WARN" "$DOC_ERR"
    [ "$DOC_ERR" -eq 0 ]
}

cmd_help() {
    cat <<'EOF'
isoclaude — run Claude Code in a sandboxed container.

USAGE
    isoclaude [SUBCOMMAND] [ARGS...]

DEFAULT
    With no subcommand (or with `run`), launches claude in the sandbox
    with PWD mounted plus ~/.claude (rw), ~/.gitconfig (ro), and ~/.ssh
    (ro). Args after `run` (or after `--`) are passed to claude.

SUBCOMMANDS
    run [ARGS]              Explicit form of the default.
    shell [ARGS]            Launch a bash shell in the sandbox.
    init                    Scaffold .isoclaude/ in the current dir.
    build                   Force-rebuild the base image at the current pin.
    version                 Show global pin, project pin, image label,
                            npm latest, project root, runtime.
    update [VERSION]        Update global pin to VERSION (default: npm
                            latest) and rebuild.
    update --check          Compare global pin to npm latest, no changes.
    pin [VERSION]           Set per-project pin to VERSION (default:
                            current global pin) and rebuild.
    prune [--all]           Remove built project images. Without --all,
                            keeps the current project's active image.
    sync-auth               macOS only. Copy Claude Code's keychain
                            credentials to ~/.claude/.credentials.json so
                            the in-container claude can authenticate.
                            (Each isoclaude run also auto-refreshes
                            silently when the keychain content changes.)
    doctor                  Diagnose runtime, image, auth, and project
                            state. Exits 0 if no errors.
    uninstall [--purge]     Remove the wrapper and ~/.isoclaude/. With
              [--yes|-y]    --purge, also removes all isoclaude images.
                            Prompts for confirmation unless --yes.
    help                    Show this message.

GLOBAL FLAGS
    --yolo, -Y              Pass --dangerously-skip-permissions to claude,
                            so it stops asking for permission on every
                            tool call. The sandbox is your safety net.
                            Only affects `run` (the default); ignored by
                            other subcommands. Strippable from anywhere
                            in the args.

ENVIRONMENT
    ISOCLAUDE_HOME           Override the install dir (default: ~/.isoclaude).
    ISOCLAUDE_RUNTIME        Force a specific runtime (e.g. docker, container).
    ISOCLAUDE_BASE_IMAGE     Override base image tag.
    ISOCLAUDE_DRY_RUN=1      Print the runtime invocation; don't exec.
    ISOCLAUDE_YOLO=1         Same as passing --yolo on every invocation.
EOF
}

main() {
    # Scan for global flags (currently just --yolo / -Y), strip them, and
    # remember in YOLO. Order-independent up to `--`: once we see the
    # separator, everything after is preserved as a literal arg (so users
    # can pass a literal `--yolo` to claude if they really need to).
    YOLO="${ISOCLAUDE_YOLO:-0}"
    local args=() arg seen_dashdash=0
    for arg in "$@"; do
        if [ "$seen_dashdash" = 0 ]; then
            case "$arg" in
                --yolo|-Y) YOLO=1; continue ;;
                --)        seen_dashdash=1 ;;  # fall through, preserve --
            esac
        fi
        args+=("$arg")
    done
    set -- "${args[@]}"

    case "${1:-}" in
        run)            shift; cmd_run "$@" ;;
        shell)          shift; cmd_shell "$@" ;;
        init)           shift; cmd_init "$@" ;;
        build)          shift; cmd_build "$@" ;;
        version)        shift; cmd_version "$@" ;;
        update)         shift; cmd_update "$@" ;;
        pin)            shift; cmd_pin "$@" ;;
        prune)          shift; cmd_prune "$@" ;;
        sync-auth)      shift; cmd_sync_auth "$@" ;;
        doctor)         shift; cmd_doctor "$@" ;;
        uninstall)      shift; cmd_uninstall "$@" ;;
        help|-h|--help) cmd_help ;;
        --)             shift; cmd_run "$@" ;;
        "")             cmd_run ;;
        *)              cmd_run "$@" ;;
    esac
}

# Only run main when executed directly, not when sourced (for tests).
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
