# Base image for isoclaude.
#
# Builds debian-slim with node, git, gosu, and a non-root `claude` user.
# The actual Claude Code CLI is installed at a pinned version supplied via
# the CLAUDE_VERSION build arg, and recorded in an image label so the
# wrapper can detect drift and trigger rebuilds.

FROM debian:trixie-slim

ARG CLAUDE_VERSION
RUN test -n "$CLAUDE_VERSION" || (echo "CLAUDE_VERSION build-arg is required" >&2; exit 1)

# The gh apt source is registered BEFORE the nodesource setup script so
# nodesource's internal `apt-get update` refreshes both lists in one
# pass (saves a redundant update).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates curl git gosu gnupg openssh-client sudo \
 && install -m 0755 -d /etc/apt/keyrings \
 && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
 && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
 && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
 && apt-get install -y --no-install-recommends nodejs gh \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

RUN npm install -g "@anthropic-ai/claude-code@${CLAUDE_VERSION}"

RUN groupadd -g 1000 claude \
 && useradd -m -u 1000 -g 1000 -s /bin/bash claude

# Passwordless sudo for the claude user. The whole container is already a
# sandbox; the privilege boundary is the container's filesystem (which is
# thrown away on exit). So we let claude apt-get install / sudo anything
# inside without an interactive password prompt. claude still runs as a
# non-root user by default — host-mounted dirs land owned by your host
# user, not root.
RUN echo 'claude ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/claude \
 && chmod 0440 /etc/sudoers.d/claude

# Some bind-mount runtimes (notably Apple `container`) present the mount-
# point directory as root-owned even when its contents have the correct
# UIDs. Git's safe.directory check then rejects any repo at the mount
# root. Inside an explicit sandbox we trust whatever's mounted in.
RUN git config --system --add safe.directory '*'

COPY entrypoint.sh /usr/local/bin/isoclaude-entrypoint
COPY mouse-filter.js /usr/local/lib/isoclaude/mouse-filter.js
COPY pty-filter.sh /usr/local/bin/isoclaude-pty-filter
RUN chmod +x /usr/local/bin/isoclaude-entrypoint /usr/local/bin/isoclaude-pty-filter

ENV HOME=/home/claude
LABEL isoclaude.claude_version="${CLAUDE_VERSION}"

ENTRYPOINT ["/usr/local/bin/isoclaude-entrypoint"]
CMD ["claude"]
